{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs",
  "plugin": [],
  "lang": "zh",
  "locales": {
    "zh": {
      "kind_project": "项目",
      "kind_module": "模块",
      "kind_namespace": "命名空间",
      "kind_enum": "枚举",
      "kind_enum_member": "枚举成员",
      "kind_class": "类",
      "kind_interface": "接口",
      "kind_type_alias": "类型别名",
      "kind_constructor": "构造函数",
      "kind_property": "属性",
      "kind_variable": "变量",
      "kind_function": "函数",
      "kind_accessor": "访问器",
      "kind_method": "方法",
      "kind_parameter": "参数",
      "kind_type_parameter": "类型参数",
      "kind_type_literal": "类型字面量",
      "kind_index_signature": "索引签名",
      "kind_get_signature": "获取签名",
      "kind_set_signature": "设置签名",
      "kind_call_signature": "调用签名",
      "kind_constructor_signature": "构造签名",
      "flag_public": "公共",
      "flag_private": "私有",
      "flag_protected": "受保护",
      "flag_static": "静态",
      "flag_readonly": "只读",
      "flag_abstract": "抽象",
      "flag_optional": "可选",
      "flag_const": "常量",
      "kind_document": "文档",
      "kind_reference": "引用"
    }
  },
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "excludeExternals": true,
  "includeVersion": true,
  "githubPages": true,
  "readme": "README.md",
  "name": "@yuantest/playwright",
  "navigationLinks": {
    "GitHub": "https://github.com/yuandiv/yuantest-playwright",
    "npm": "https://www.npmjs.com/package/@yuantest/playwright"
  },
  "sidebarLinks": {
    "GitHub": "https://github.com/yuandiv/yuantest-playwright"
  },
  "sort": ["source-order"],
  "kindSortOrder": [
    "Document",
    "Reference",
    "Project",
    "Module",
    "Namespace",
    "Enum",
    "EnumMember",
    "Class",
    "Interface",
    "TypeAlias",
    "Constructor",
    "Property",
    "Variable",
    "Function",
    "Accessor",
    "Method",
    "Parameter",
    "TypeParameter",
    "TypeLiteral"
  ],
  "visibilityFilters": {
    "protected": true,
    "private": false,
    "inherited": true,
    "external": false
  },
  "searchInComments": true,
  "cleanOutputDir": true
}
