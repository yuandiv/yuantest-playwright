<% if (tags && tags.length > 0) { %>
<div class="section">
    <div class="section-header">
        <span>Tags</span>
        <span class="badge" style="background:#f3f4f6;color:#4b5563"><%- tags.length %> tags</span>
    </div>
    <div class="section-body">
        <% tags.forEach(function(t) { %>
            <span class="tag tag-<%- t.name %>">@<%- t.name %></span>
            <span style="font-size:12px;color:#9ca3af"><%- t.count %> tests</span>
        <% }); %>
    </div>
</div>
<% } %>
