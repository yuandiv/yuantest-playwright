<% if (traces && traces.total > 0) { %>
<div class="section">
    <div class="section-header">
        <span>Traces</span>
        <span class="badge" style="background:#f3e8ff;color:#7c3aed"><%- traces.total %> trace(s)</span>
    </div>
    <div class="section-body">
        <% traces.files.forEach(function(t) { %>
            <a class="trace-link" href="#" onclick="return false">
                &#128269; <%- t.testName %>
                <span style="color:#9ca3af">(<%- formatFileSize(t.size) %>)</span>
            </a>
        <% }); %>
    </div>
</div>
<% } %>
