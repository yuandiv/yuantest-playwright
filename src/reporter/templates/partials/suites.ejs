<div class="suites">
    <% suites.forEach(function(suite) { %>
        <div class="suite">
            <div class="suite-header">
                <span class="suite-name"><%- escapeHtml(suite.name) %></span>
                <span class="suite-stats"><%- suite.passed %> passed &bull; <%- suite.failed %> failed &bull; <%- suite.skipped %> skipped</span>
            </div>
            <div class="suite-tests">
                <% suite.tests.forEach(function(test) { %>
                    <div class="test">
                        <div class="test-status <%- test.status %>"></div>
                        <span class="test-title"><%- escapeHtml(test.title) %></span>
                        <span class="test-duration"><%- (test.duration / 1000).toFixed(2) %>s</span>
                    </div>
                    <% if (test.error) { %>
                        <div class="error-message"><%- escapeHtml(test.error) %></div>
                    <% } %>
                    <% if (test.screenshots && test.screenshots.length > 0) { %>
                        <div style="padding: 8px 20px"><span class="badge" style="background:#dbeafe;color:#1d4ed8"><%- test.screenshots.length %> screenshot(s)</span></div>
                    <% } %>
                    <% if (test.traces && test.traces.length > 0) { %>
                        <div style="padding: 8px 20px"><span class="badge" style="background:#f3e8ff;color:#7c3aed"><%- test.traces.length %> trace(s)</span></div>
                    <% } %>
                <% }); %>
            </div>
        </div>
    <% }); %>
</div>
